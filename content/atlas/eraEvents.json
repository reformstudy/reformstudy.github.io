      "timeframe": "33 AD – Present",
      "events": [
        {
          "id": "pentecost",
          "date": "c. 33 AD",
          "title": "Pentecost",
          "loc": "Jerusalem",
          "coords": {
            "x": 776,
            "y": 391
          },
          "desc": "The Holy Spirit is poured out on the disciples, empowering them to preach the gospel to all nations.",
          "scripture": "Acts 2:1-4",
          "theme": "New Covenant"
        },
        {
          "id": "antioch",
          "date": "c. 49 AD",
          "title": "Missions from Antioch",
          "loc": "Antioch",
          "coords": {
            "x": 792,
            "y": 299
          },
          "desc": "The church at Antioch commissions Paul and Barnabas. It becomes the launchpad for Gentile missions.",
          "scripture": "Acts 13:1-3",
          "theme": "Gentile Inclusion"
        },
        {
          "id": "athens",
          "date": "c. 51 AD",
          "title": "Paul at the Areopagus",
          "loc": "Athens, Achaia",
          "coords": {
            "x": 578,
            "y": 259
          },
          "desc": "Paul delivers a masterclass in apologetics, using their altar \"To the unknown god\" to declare the sovereign Creator.",
          "scripture": "Acts 17:22-31",
          "theme": "General Revelation"
        },
        {
          "id": "rome",
          "date": "c. 60 AD",
          "title": "Paul in Rome",
          "loc": "Rome",
          "coords": {
            "x": 386,
            "y": 174
          },
          "desc": "Paul arrives in Rome as a prisoner, preaching the kingdom of God with all boldness and without hindrance.",
          "scripture": "Acts 28:30-31",
          "theme": "Gospel Advance"
        }
      ]
    }
